{
    "extends": [
        "github>mailerlite/renovate-config:base"
    ],
    "enabledManagers": [
        "custom.regex",
        "dockerfile",
        "docker-compose",
        "helmv3",
        "github-actions"
    ],
    "customManagers": [
        {
            "customType": "regex",
            "managerFilePatterns": ["/Dockerfile(\\.[\\w-]+)?$/"],
            "matchStrings": [
                "# renovate: datasource=(?<datasource>.*?) depName=(?<depName>.*?)( extractVersion=(?<extractVersion>.+?))?( versioning=(?<versioning>.*?))?( currentDigest=(?<currentDigest>sha256:[a-f0-9]+))?\n.*?_VERSION=[\"]?(?<currentValue>.*[^\"\\n])"
            ],
            "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}"
        },
        {
            "customType": "regex",
            "managerFilePatterns": ["/Dockerfile(\\.[\\w-]+)?$/"],
            "matchStrings": [
                "(?:FROM|COPY --from=)(?:.*?/mailerlitehub/)(?<depName>[a-z0-9./-]+)(?::(?<currentValue>[a-z0-9.-]+))?(?:@(?<currentDigest>sha256:[a-f0-9]+))?"
            ],
            "datasourceTemplate": "docker",
            "registryUrlTemplate": "https://europe-docker.pkg.dev/mailerlitehub/"
        },
        {
            "customType": "regex",
            "managerFilePatterns": ["/helm(chart)?/values\\.(dev|prod|staging|production)\\.ya?ml$/"],
            "matchStrings": [
                "# renovate: datasource=(?<datasource>.*?) depName=(?<depName>.*?)?\n.*?image: .*?:(?<currentValue>[^\\n@]*)(?:@(?<currentDigest>sha256:[a-f0-9]+))?"
            ],
            "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}"
        }
    ],
    "packageRules": [
        {
            "description": "Disable dockerfile manager for internal images - handled by custom regex manager",
            "matchManagers": ["dockerfile"],
            "matchPackagePatterns": ["mailerlitehub"],
            "enabled": false
        },
        {
            "description": "Landings registry",
            "matchPackagePatterns": ["^europe-docker.pkg.dev/mailerlite-v2/landings/landings"],
            "registryUrls": ["https://europe-docker.pkg.dev/mailerlite-v2/"]
        },
        {
            "description": "Docker images - separate PRs per package",
            "matchDatasources": ["docker"],
            "addLabels": ["docker"],
            "reviewers": ["team:sre"]
        },
        {
            "description": "GitHub Actions - separate PRs per package",
            "matchDatasources": ["github-actions"],
            "addLabels": ["github"],
            "reviewers": ["team:sre"]
        },
        {
            "description": "Elasticsearch - disable major updates",
            "matchPackagePatterns": ["elasticsearch"],
            "matchUpdateTypes": ["major"],
            "enabled": false
        },
        {
            "description": "Helm charts - separate PRs per package",
            "matchDatasources": ["helm"],
            "addLabels": ["helm"],
            "reviewers": ["team:sre"]
        },
        {
            "description": "GitHub releases - separate PRs per package",
            "matchDatasources": ["github-releases"],
            "reviewers": ["team:sre"]
        }
    ]
}
