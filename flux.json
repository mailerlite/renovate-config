{
    "extends": [
        "github>mailerlite/renovate-config:base"
    ],
    "enabledManagers": [
        "custom.regex",
        "custom.jsonata",
        "github-actions",
        "kubernetes",
        "flux"
    ],
    "kubernetes": {
        "managerFilePatterns": [
            "/mailer.+\\.ya?ml$/",
            "/clusters?/.+\\.ya?ml$/",
            "/base/.+\\.ya?ml$/"
        ]
    },
    "flux": {
        "managerFilePatterns": [
            "/mailer.+\\.ya?ml$/",
            "/clusters?/.+\\.ya?ml$/",
            "/base/.+\\.ya?ml$/"
        ]
    },
    "customManagers": [
        {
            "customType": "regex",
            "managerFilePatterns": [
                "/mailer.+\\.ya?ml$/",
                "/clusters?/.+\\.ya?ml$/",
                "/base/.+\\.ya?ml$/"
            ],
            "matchStrings": [
                "# renovate: datasource=(?<datasource>.*?) registryUrl=(?<registryUrl>.*?) chart=(?<depName>.*)\n *version: (?<currentValue>.*)"
            ],
            "depTypeTemplate": "helm-oci"
        },
        {
            "customType": "regex",
            "managerFilePatterns": [
                "/mailer.+\\.ya?ml$/",
                "/clusters?/.+\\.ya?ml$/",
                "/base/.+\\.ya?ml$/"
            ],
            "matchStrings": [
                "# renovate: datasource=(?<datasource>.*?) depName=(?<depName>.*?)?(?:\n.*?)(?:\n.*?)?tag: .*?(?<currentValue>[^\\n@]*)(?:@(?<currentDigest>sha256:[a-f0-9]+))?",
                "# renovate: datasource=(?<datasource>.*?) depName=(?<depName>.*?)?\n.*?image: .*?:(?<currentValue>[^\\n@]*)(?:@(?<currentDigest>sha256:[a-f0-9]+))?"
            ]
        },
        {
            "description": "app-template: repository+tag+digest - write digest to separate digest field",
            "customType": "jsonata",
            "fileFormat": "yaml",
            "managerFilePatterns": [
                "/mailer.+\\.ya?ml$/",
                "/clusters?/.+\\.ya?ml$/",
                "/base/.+\\.ya?ml$/"
            ],
            "matchStrings": [
                "**.image[$exists(repository) and $exists(tag) and $exists(digest)].{ \"depName\": $exists($.registry) ? $.registry & \"/\" & $.repository : $.repository, \"currentValue\": $.tag, \"currentDigest\": $.digest }"
            ],
            "datasourceTemplate": "docker",
            "depTypeTemplate": "app-template-with-digest"
        },
        {
            "description": "app-template: repository+tag without digest - write digest inline with tag",
            "customType": "jsonata",
            "fileFormat": "yaml",
            "managerFilePatterns": [
                "/mailer.+\\.ya?ml$/",
                "/clusters?/.+\\.ya?ml$/",
                "/base/.+\\.ya?ml$/"
            ],
            "matchStrings": [
                "**.image[$exists(repository) and $exists(tag) and $not($exists(digest))].{ \"depName\": $exists($.registry) ? $.registry & \"/\" & $.repository : $.repository, \"currentValue\": $substringBefore($.tag, \"@\"), \"currentDigest\": $contains($.tag, \"@\") ? $substringAfter($.tag, \"@\") : \"\" }"
            ],
            "datasourceTemplate": "docker",
            "depTypeTemplate": "app-template-inline-digest"
        },
        {
            "customType": "regex",
            "managerFilePatterns": [
                "/^\\.pre-commit-config\\.ya?ml$/"
            ],
            "matchStrings": [
                "# renovate: datasource=(?<datasource>.*?) depName=(?<depName>.*?)?\n.*?rev: .*?(?<currentValue>.*)"
            ]
        }
    ],
    "packageRules": [
        {
            "description": "Internal Docker images in Flux - enable digest pinning (overrides base default)",
            "matchPackagePatterns": ["docker\\.pkg\\.dev/(mailerlitehub|mailerlite-gcp|mailercheck-usa|mailersend-214215|mailerlite-v2)/"],
            "matchDatasources": ["docker"],
            "pinDigests": true
        },
        {
            "description": "flux manager - disable digest pinning, inline tag@digest format is not valid for HelmRelease values, handled by custom managers",
            "matchManagers": ["flux"],
            "pinDigests": false
        },
        {
            "description": "app-template images with dedicated digest field - enable digest pinning so digest field is updated alongside tag on version bumps",
            "matchDepTypes": ["app-template-with-digest"],
            "pinDigests": true
        },
        {
            "description": "OCI helm charts via annotation - disable digest pinning, inline tag@digest format is not valid for helm",
            "matchDepTypes": ["helm-oci"],
            "pinDigests": false
        },
        {
            "description": "Helm and Docker - split by environment, separate minor/patch by default",
            "matchDatasources": ["helm", "docker"],
            "separateMinorPatch": true,
            "ignoreDeprecated": true,
            "additionalBranchPrefix": "{{#if (containsString packageFileDir 'clusters/staging')}}staging{{else}}{{#if (containsString packageFileDir 'clusters/dev')}}dev{{else}}{{#if (containsString packageFileDir 'clusters/prod')}}prod{{else}}{{#if (containsString packageFileDir 'base/')}}base{{/if}}{{/if}}{{/if}}{{/if}}-",
            "addLabels": ["{{#if (containsString packageFileDir 'clusters/staging')}}staging{{/if}}", "{{#if (containsString packageFileDir 'clusters/dev')}}dev{{/if}}", "{{#if (containsString packageFileDir 'clusters/prod')}}prod{{/if}}", "{{#if (containsString packageFileDir 'base/')}}base{{/if}}"]
        },
        {
            "description": "Internal Docker in dev/staging - no minor/patch split, both automerge so separation adds noise",
            "matchPackagePatterns": ["docker\\.pkg\\.dev/(mailerlitehub|mailerlite-gcp|mailercheck-usa|mailersend-214215|mailerlite-v2)/"],
            "matchDatasources": ["docker"],
            "matchFileNames": ["**/clusters/dev/**", "**/clusters/staging/**"],
            "separateMinorPatch": false
        },
        {
            "description": "Helm charts label",
            "matchDatasources": ["helm"],
            "addLabels": ["helm"]
        },
        {
            "description": "Docker images label",
            "matchDatasources": ["docker"],
            "addLabels": ["docker"]
        },
        {
            "description": "VictoriaMetrics label",
            "matchPackagePatterns": ["^victoriametrics"],
            "addLabels": ["VictoriaMetrics"]
        },
        {
            "description": "app-template patch updates",
            "groupName": "app-template patch dependencies",
            "groupSlug": "app-template-patch",
            "matchPackageNames": ["app-template"],
            "matchUpdateTypes": ["patch"]
        },
        {
            "description": "app-template minor updates",
            "groupName": "app-template minor dependencies",
            "groupSlug": "app-template-minor",
            "matchPackageNames": ["app-template"],
            "matchUpdateTypes": ["minor"]
        },
        {
            "description": "Auto-merge internal Docker updates in dev/staging - patch/minor/pinDigest",
            "matchPackagePatterns": ["docker\\.pkg\\.dev/(mailerlitehub|mailerlite-gcp|mailercheck-usa|mailersend-214215|mailerlite-v2)/"],
            "matchUpdateTypes": ["patch", "minor", "pinDigest"],
            "matchFileNames": ["**/clusters/dev/**", "**/clusters/staging/**"],
            "automerge": true,
            "addLabels": ["automerge"]
        },
        {
            "description": "Auto-merge internal Docker patch/pinDigest in prod",
            "matchPackagePatterns": ["docker\\.pkg\\.dev/(mailerlitehub|mailerlite-gcp|mailercheck-usa|mailersend-214215|mailerlite-v2)/"],
            "matchUpdateTypes": ["patch", "pinDigest"],
            "matchFileNames": ["**/clusters/prod/**", "**/clusters/production/**"],
            "automerge": true,
            "addLabels": ["automerge"]
        },
        {
            "description": "Auto-merge internal Docker minor in prod - 1 day buffer as soak gate",
            "matchPackagePatterns": ["docker\\.pkg\\.dev/(mailerlitehub|mailerlite-gcp|mailercheck-usa|mailersend-214215|mailerlite-v2)/"],
            "matchUpdateTypes": ["minor"],
            "matchFileNames": ["**/clusters/prod/**", "**/clusters/production/**"],
            "minimumReleaseAge": "1 day",
            "automerge": true,
            "addLabels": ["automerge"]
        },
        {
            "description": "Explicitly disabled packages - add/remove package names here to manage the list",
            "matchPackageNames": [
                "europe-docker.pkg.dev/mailerlite-gcp/mailerlite/mailerlite-prod"
            ],
            "enabled": false
        },
        {
            "description": "Packages that get PRs but must never auto-merge - add/remove package names here to manage the list",
            "matchPackageNames": [
                "europe-docker.pkg.dev/mailerlitehub/pgbouncer/pgbouncer"
            ],
            "automerge": false
        }
    ]
}
