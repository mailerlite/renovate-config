{
    "semanticCommits": "enabled",
    "dependencyDashboard": true,
    "pinDigests": true,
    "dependencyDashboardAutoclose": true,
    "suppressNotifications": ["prIgnoreNotification"],
    "rebaseWhen": "behind-base-branch",
    "labels": ["renovate"],
    "onboardingConfigFileName": ".github/renovate.json",
    "prConcurrentLimit": 0,
    "prHourlyLimit": 0,
    "minimumReleaseAge": "3 days",
    "timezone": "UTC",
    "osvVulnerabilityAlerts": true,
    "vulnerabilityAlerts": {
        "labels": ["security"],
        "schedule": ["* * * * *"],
        "minimumReleaseAge": "0 days",
        "prPriority": 99
    },
    "packageRules": [
        {
            "description": "mailerlite/workflows and mailerlite/base-docker-images reusable workflows - pinned at main, no versioning",
            "matchManagers": ["github-actions"],
            "matchPackagePatterns": ["mailerlite/workflows", "mailerlite/base-docker-images"],
            "enabled": false,
            "pinDigests": false
        },
        {
            "description": "mailerlite-v2 GCP registry - explicit registryUrl required for Renovate to query it correctly",
            "matchPackagePatterns": ["^europe-docker.pkg.dev/mailerlite-v2/"],
            "matchDatasources": ["docker"],
            "registryUrls": ["https://europe-docker.pkg.dev/mailerlite-v2/"]
        },
        {
            "description": "Internal Docker images from GCP artifact registry - no minimum release age, no digest pinning by default",
            "matchPackagePatterns": ["docker\\.pkg\\.dev/(mailerlitehub|mailerlite-gcp|mailercheck-usa|mailersend-214215|mailerlite-v2)/"],
            "matchDatasources": ["docker"],
            "minimumReleaseAge": "0 days",
            "pinDigests": false
        },
        {
            "description": "Internal GitHub Actions - no minimum release age, no digest pinning",
            "matchManagers": ["github-actions"],
            "matchPackagePatterns": ["^(mailerlite|mailersend|mailercheck)/"],
            "minimumReleaseAge": "0 days",
            "pinDigests": false
        },
        {
            "description": "Internal Docker patch/minor - auto-merge across all repos",
            "matchPackagePatterns": ["docker\\.pkg\\.dev/(mailerlitehub|mailerlite-gcp|mailercheck-usa|mailersend-214215|mailerlite-v2)/"],
            "matchDatasources": ["docker"],
            "matchUpdateTypes": ["patch", "minor"],
            "automerge": true,
            "addLabels": ["automerge"]
        },
        {
            "description": "Internal GHA patch/minor - auto-merge across all repos",
            "matchManagers": ["github-actions"],
            "matchPackagePatterns": ["^(mailerlite|mailersend|mailercheck)/"],
            "matchUpdateTypes": ["patch", "minor"],
            "automerge": true,
            "addLabels": ["automerge"]
        },
        {
            "description": "Group digest-only pins into a single PR - no version changes",
            "matchManagers": ["dockerfile", "docker-compose"],
            "matchUpdateTypes": ["pinDigest"],
            "groupName": "Docker digest pins"
        },
        {
            "description": "images.yaml version slots - patch updates only, never promote to a new minor/major",
            "matchFileNames": ["**/images.yaml"],
            "matchUpdateTypes": ["major", "minor"],
            "enabled": false
        },
        {
            "description": "images.yaml - one PR per package across all its tracked version slots",
            "matchFileNames": ["**/images.yaml"],
            "groupName": "{{depName}}"
        },
        {
            "description": "Explicitly disabled packages - add/remove package names here to manage the list",
            "matchPackageNames": [
                "europe-docker.pkg.dev/mailerlite-gcp/mailerlite/mailerlite-prod"
            ],
            "enabled": false
        },
        {
            "description": "Packages that get PRs but must never auto-merge - add/remove package names here to manage the list",
            "matchPackageNames": [
                "europe-docker.pkg.dev/mailerlitehub/pgbouncer/pgbouncer"
            ],
            "automerge": false
        }
    ],
    "enabledManagers": [
        "custom.regex",
        "dockerfile",
        "docker-compose",
        "github-actions"
    ],
    "dockerfile": {
        "managerFilePatterns": [
            "/^Makefile$/",
            "/Dockerfile(\\.[\\w-]+)?$/"
        ]
    },
    "customManagers": [
        {
            "customType": "regex",
            "managerFilePatterns": ["/(^|/)images\\.yaml$/"],
            "matchStringsStrategy": "recursive",
            "matchStrings": [
                "versions:\\s+#\\s+renovate:\\s+datasource=(?<datasource>[^\\s\\n]+)\\s+depName=(?<depName>[^\\s\\n]+)(?:\\s+extractVersion=(?<extractVersion>[^\\s\\n]+))?(?:\\s+versioning=(?<versioning>[^\\s\\n]+))?\\n(?:[ \\t]+-[^\\n]+\\n?)+",
                "-\\s+\"(?<currentValue>[^\"]+)\""
            ],
            "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}"
        }
    ]
}
