{
    "semanticCommits": "enabled",
    "dependencyDashboard": true,
    "pinDigests": true,
    "dependencyDashboardAutoclose": true,
    "suppressNotifications": ["prIgnoreNotification"],
    "rebaseWhen": "behind-base-branch",
    "labels": ["renovate"],
    "onboardingConfigFileName": ".github/renovate.json",
    "prConcurrentLimit": 0,
    "prHourlyLimit": 0,
    "minimumReleaseAge": "1 day",
    "timezone": "UTC",
    "osvVulnerabilityAlerts": true,
    "vulnerabilityAlerts": {
        "labels": ["security"],
        "schedule": ["* * * * *"],
        "minimumReleaseAge": "0 days",
        "prPriority": 99
    },
    "packageRules": [
        {
            "description": "mailerlite/workflows - reusable workflows repo with no releases or versioning",
            "matchPackageNames": ["mailerlite/workflows"],
            "enabled": false
        },
        {
            "description": "Major updates - require dashboard approval",
            "matchUpdateTypes": ["major"],
            "dependencyDashboardApproval": true
        },
        {
            "description": "Group digest-only pins into a single PR - no version changes",
            "matchManagers": ["dockerfile", "docker-compose"],
            "matchUpdateTypes": ["pinDigest"],
            "groupName": "Docker digest pins"
        }
    ],
    "dockerfile": {
        "managerFilePatterns": [
            "/^Makefile$/",
            "/Dockerfile(\\.[\\w-]+)?$/"
        ]
    }
}
